#!/usr/bin/env ruby
require "bundler/setup"
require "optparse"
require "fileutils"
require "json"

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "config"
require "cache"
require "api/client"
require "api/auth"
require "api/sources"
require "api/dashboards"
require "api/charts"
require "tui/app"

config = Config.new
cache  = Cache.new
opts   = {}

OptionParser.new do |o|
  o.banner = "Usage: bsdash [options]"

  o.on("-C", "--session-cookie COOKIE", "Save session cookie and exit") do |v|
    config["session_cookie"] = v
    puts "Session cookie saved."
    exit
  end

  o.on("-t", "--auth-token TOKEN",       "Auth token")              { |v| config["auth_token"]       = v }
  o.on("-r", "--refresh-interval SECS", "Refresh interval (secs)") { |v| config["refresh_interval"] = v.to_i }
  o.on("-s", "--source NAME",           "Source name")             { |v| opts[:source]               = v }
  o.on("-d", "--dashboard NAME",        "Dashboard name")          { |v| opts[:dashboard]            = v }
  o.on("-c", "--chart NAME",            "Chart name")              { |v| opts[:chart]                = v }
end.parse!

if !config["auth_token"]
  abort "No auth_token configured. Run with -t <auth_token> to set one."
end

# Fetch source

if opts[:source]
  client = API::Client.new(auth_token: config["auth_token"])
  source_data = API::Sources.new(client).find(opts[:source])
  cache.source = source_data
elsif !cache.source
  abort "No source configured. Run with -s <name> to set one."
end

source = cache.source

# Resolve chart identity (dashboard + chart name) from flags or cache

if opts[:dashboard] && opts[:chart]
  cache.chart = { "dashboard_name" => opts[:dashboard], "name" => opts[:chart] }
elsif !cache.chart
  abort "No chart configured. Run with -d <dashboard> -c <chart> to set one."
end

# Always fetch the query fresh so changes in the dashboard are picked up

client ||= API::Client.new(auth_token: config["auth_token"])
chart = API::Dashboards.new(client).find_chart(
  dashboard_name: cache.chart["dashboard_name"],
  chart_name:     cache.chart["name"]
)

# Persist names + settings but not the query
cache.chart = {
  "dashboard_name" => cache.chart["dashboard_name"],
  "name"           => chart["name"],
  "settings"       => chart["settings"]
}

# Pass dashboard_name into the chart hash so the TUI can re-fetch on demand
chart["dashboard_name"] = cache.chart["dashboard_name"]

# Launch TUI

TUI::App.new(config: config, source: source, chart: chart).run
